<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="K388S_SDK.MainPage">

    <StackLayout Padding="20">
        <Frame BackgroundColor="#2196F3" Padding="24" CornerRadius="0">
            <Label Text="Welcome to Xamarin.Forms!" HorizontalTextAlignment="Center" TextColor="White" FontSize="36"/>
        </Frame>
        <Button
            x:Name="ScanButton"
            Text="StartScan"
            Clicked="ScanButton_Clicked"/>
        <Button
            x:Name="PrintTicketButton"
            Text="Print Ticket (​​Continuous paper)"
            Clicked="PrintTicketButton_Clicked"/>

        <Button
            x:Name="PrintLabelButton"
            Text="Print Label"
            Clicked="PrintLabelButton_Clicked"/>

        <Button
            x:Name="PrintCustomCMDButton"
            Text="PrintCustomCMD"
            Clicked="PrintCustomCMD_Clicked"/>
        <Label
            x:Name="InfoTv"
            Text="Hello, World!"
            FontSize="20" />
    </StackLayout>

</ContentPage>
